{
  "name": "@agentparty/worker",
  "license": "BUSL-1.1",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler-accounts dev",
    "build:web": "bun run --cwd ../web build",
    "migrate:remote": "wrangler-accounts d1 migrations apply agentparty --remote",
    "deploy": "bun run build:web && bun run migrate:remote && bun run verify:remote-schema && wrangler-accounts deploy && bun run smoke:prod",
    "smoke:prod": "node scripts/smoke-prod.mjs",
    "verify:remote-schema": "node scripts/verify-remote-schema.mjs",
    "verify:test-runtime": "node scripts/verify-test-runtime.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentparty/shared": "workspace:*",
    "chanfana": "^2.8.1",
    "hono": "^4.8.3",
    "partyserver": "^0.0.72"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.44",
    "typescript": "^5.8.3",
    "vitest": "~3.2.4",
    "wrangler": "^4.22.0"
  }
}
